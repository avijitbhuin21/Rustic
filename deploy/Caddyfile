# Caddy reverse proxy for rustic-server.
#
# Caddy auto-provisions a Let's Encrypt cert for a real domain, or an internal
# cert for `localhost`. Critically it forwards the WebSocket `Upgrade` /
# `Connection` headers transparently, so `/ws` works without extra config —
# `reverse_proxy` handles upgrades natively.

{$RUSTIC_DOMAIN} {
	encode zstd gzip

	# Everything (HTTP commands, /ws WebSocket, static SPA) goes to the server.
	reverse_proxy rustic:8787 {
		# Pass the real client IP through so the server's login rate-limiter
		# keys off the visitor, not Caddy.
		header_up X-Forwarded-For {remote_host}
		header_up X-Real-IP {remote_host}
	}
}

# OPTIONAL — subdomain port-forwarding ("open VM dev server in my own browser").
# Set RUSTIC_PREVIEW_DOMAIN=preview.example.com and RUSTIC_COOKIE_DOMAIN=.example.com
# in .env, point a wildcard DNS record (*.preview.example.com) here, and add a
# wildcard TLS cert (DNS challenge). The server routes <port>.preview.example.com
# to 127.0.0.1:<port> internally — Caddy just needs to forward the host verbatim:
#
# *.preview.example.com {
# 	encode zstd gzip
# 	reverse_proxy rustic:8787 {
# 		header_up X-Forwarded-For {remote_host}
# 	}
# }

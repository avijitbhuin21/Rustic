# ── rustic-server configuration ──────────────────────────────────────────────
# Copy to `.env` and fill in. The server loads this file from its working
# directory on startup (existing environment variables take precedence).

# REQUIRED. The login password gating every route. The server refuses to start
# without it — there is intentionally no "no password" mode for a public port.
# Set a strong, unique password before deploying (NOT "change-me").
RUSTIC_AUTH_PASSWORD=change-me

# Secret used to sign session tokens (HMAC-SHA256). If unset, a random
# per-process value is used and all sessions are invalidated on every restart.
# Set a stable value so logins survive restarts.
# Generate with: openssl rand -hex 32
RUSTIC_SESSION_SECRET=

# Address to bind. Inside the container, bind all interfaces; the reverse proxy
# (Caddy/nginx) or the VPN is what actually exposes it.
# NOTE: On Railway (or any PaaS that injects $PORT), LEAVE THIS UNSET — the
# server falls back to binding 0.0.0.0:$PORT. Setting it here pins the port and
# overrides $PORT.
RUSTIC_BIND_ADDR=0.0.0.0:8787

# Application data directory: rustic.db, logs/, file-history/, secrets.json.
# Mount this as a volume so state survives container restarts.
RUSTIC_DATA_DIR=/data

# Directory containing the built web frontend (Vite `dist`). The image copies
# the build to /app/dist.
RUSTIC_STATIC_DIR=/app/dist

# Session lifetime in seconds (default: 7 days).
RUSTIC_SESSION_TTL_SECS=604800

# Login brute-force throttle: lock an IP after this many consecutive failures…
RUSTIC_LOGIN_MAX_ATTEMPTS=5
# …for this many seconds.
RUSTIC_LOGIN_LOCKOUT_SECS=300

# Log verbosity (tracing EnvFilter syntax).
RUST_LOG=info,reqwest=warn,hyper=warn,tower=warn

# Embedded VM browser (web build only). The image installs `chromium` and sets
# CHROME_BIN; override only for a non-standard binary. The loopback CDP port is
# never published — leave the default unless it collides with something on the
# VM. Both are optional.
# CHROME_BIN=/usr/bin/chromium
# RUSTIC_BROWSER_DEBUG_PORT=9222

# ── Provider API keys (optional) ─────────────────────────────────────────────
# Keys can be set at runtime through the Settings UI (persisted to
# <RUSTIC_DATA_DIR>/secrets.json), OR injected here without touching disk. The
# env var name is RUSTIC_SECRET_<ACCOUNT> with the account upper-cased and every
# non-alphanumeric char replaced by '_'. Examples:
#   provider:anthropic         -> RUSTIC_SECRET_PROVIDER_ANTHROPIC
#   provider:openai            -> RUSTIC_SECRET_PROVIDER_OPENAI
#   github_token               -> RUSTIC_SECRET_GITHUB_TOKEN
# RUSTIC_SECRET_PROVIDER_ANTHROPIC=sk-ant-...
